{
  "name": "star-trail-convenience",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "validate": "node scripts/validate-story.mjs && node scripts/smoke-test.mjs",
    "generate-assets": "node scripts/generate-assets.mjs",
    "generate-audio": "bash scripts/generate-audio.sh",
    "generate-all": "npm run generate-assets && npm run download-audio",
    "cutout-sprites": "python3 scripts/remove-sprite-bg.py",
    "download-audio": "bash scripts/download-story-audio.sh"
  },
  "dependencies": {
    "howler": "^2.2.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/howler": "^2.2.13",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "sharp": "^0.34.5",
    "typescript": "^5.6.3",
    "vite": "^5.4.11"
  }
}
